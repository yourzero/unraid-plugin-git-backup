    'COMPOSE_PATH'        => '/boot/config/plugins/compose.manager/projects',
    'HAOS_ENABLED'        => 'no',
    'HAOS_HOST'           => 'homeassistant.local',
    'HAOS_PORT'           => '22',
    'HAOS_USER'           => 'root',
    'HAOS_SSH_KEY'        => '/root/.ssh/haos_backup_key',
    'HAOS_INCLUDE'        => '/config/configuration.yaml,/config/automations.yaml,/config/scripts.yaml,/config/scenes.yaml,/config/secrets.yaml,/config/customize.yaml,/config/known_devices.yaml,/config/groups.yaml,/config/packages/**,/config/custom_components/**,/config/blueprints/**,/config/www/**,/config/themes/**,/config/.storage/core.config_entries,/config/.storage/core.device_registry,/config/.storage/core.entity_registry,/config/.storage/core.area_registry,/config/.storage/lovelace*',
    'HAOS_EXCLUDE'        => '/config/home-assistant_v2.db,/config/home-assistant_v2.db-shm,/config/home-assistant_v2.db-wal,/config/tts/**,/config/deps/**,/config/.cloud/**,/config/backups/**',
    'UNRAID_ENABLED'      => 'yes',
    'UNRAID_PATHS'        => '/boot/config/go,/boot/config/network.cfg,/boot/config/ident.cfg,/boot/config/disk.cfg,/boot/config/share.cfg,/boot/config/smb-extra.conf,/boot/config/syslinux/syslinux.cfg',
