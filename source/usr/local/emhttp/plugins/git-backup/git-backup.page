$cfg = parse_plugin_cfg($plugin);
foreach ($defaults as $key => $val) {
    if (!isset($cfg[$key]) || $cfg[$key] === '') $cfg[$key] = $val;
}

// Helper: convert CSV to newline-separated for textarea display
function csv_to_lines($csv) {
    return str_replace(',', "\n", $csv);
}

// Check service status
$cron_status = trim(exec("$plugdir/rc.$plugin status 2>/dev/null"));
$is_running = (strpos($cron_status, 'running') !== false);

// Check if repo is initialized
$repo_initialized = file_exists($cfg['REPO_PATH'] . '/.git');
