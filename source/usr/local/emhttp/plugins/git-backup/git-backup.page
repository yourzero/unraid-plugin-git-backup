<script>
function toggleHaos() {
    var enabled = document.getElementById('haos_enabled').value;
    document.getElementById('haos_settings').style.display = (enabled === 'yes') ? '' : 'none';
}

// Convert textarea newlines to CSV for hidden inputs before form submit
function prepareSubmit() {
    var fields = [
        ['global_exclude_display', 'global_exclude_hidden'],
        ['haos_include_display', 'haos_include_hidden'],
        ['haos_exclude_display', 'haos_exclude_hidden'],
        ['unraid_paths_display', 'unraid_paths_hidden'],
    ];
    fields.forEach(function(pair) {
        var ta = document.getElementById(pair[0]);
        var hidden = document.getElementById(pair[1]);
        if (ta && hidden) {
            hidden.value = ta.value.split('\n')
                .map(function(l) { return l.trim(); })
                .filter(function(l) { return l.length > 0; })
                .join(',');
        }
    });
}

// Helper: all script execution goes through the PHP wrapper.
// openBox loads URLs — it does NOT execute commands directly.
function pluginExec(script, args, title, w, h) {
    var url = '/plugins/git-backup/include/exec.php?script=' +
        encodeURIComponent(script) + '&args=' + encodeURIComponent(args || '');
    openBox(url, title, w || 800, h || 600, true);
}

function runBackup(args) {
    pluginExec('backup.sh', args, 'Git Backup');
}

function initRepo() {
    pluginExec('init-repo.sh', '', 'Initialize Repository', 700, 500);
}

function viewLog() {
    var logFile = '<?=htmlspecialchars($cfg['LOG_FILE'])?>';
    // tail is a system command, use exec.php would need whitelisting.
    // Instead, read the log via PHP directly.
    openBox('/plugins/git-backup/include/viewlog.php', 'Git Backup Log', 800, 600, true);
}

function generateKey(type) {
    pluginExec('ssh-keygen.sh', type, 'Generate SSH Key (' + type + ')', 700, 500);
}

function showKey(type) {
    pluginExec('ssh-keygen.sh', 'show ' + type, 'SSH Public Key (' + type + ')', 700, 300);
}
</script>
