$cfgfile = "/boot/config/plugins/$plugin/$plugin.cfg";

// Load config with defaults
$defaults = [
    'REPO_PATH'          => '/mnt/user/appdata/git-config-backup',
    'REMOTE_URL'          => '',
    'REMOTE_NAME'         => 'origin',
    'BRANCH'              => 'main',
    'COMMIT_PREFIX'       => 'backup:',
    'PUSH_AFTER_COMMIT'   => 'yes',
    'APPDATA_PATH'        => '/mnt/user/appdata',
    'MAX_FILE_SIZE_KB'    => '500',
    'SKIP_CONTAINERS'     => '',
    'GLOBAL_EXCLUDE'      => '*.db,*.db-shm,*.db-wal,*.sqlite,*.log,*.log.*,logs/**,log/**,cache/**,Cache/**,tmp/**,temp/**,thumbnails/**,Thumbnails/**,Metadata/**,metadata/**,*.jpg,*.jpeg,*.png,*.gif,*.bmp,*.webp,*.mp4,*.mkv,*.avi,*.mp3,*.flac,*.sock,*.pid,*.lock,node_modules/**,__pycache__/**,.git/**',
